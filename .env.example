# Copy to ".env" (gitignored) and fill in the key for the provider you use with
# convert.py --provider for bulk enrichment (--fill-meanings / --explain).
# This is the BUILD-TIME key for generating the static library. It is separate
# from the in-app "Explain deeper" key, which you enter in the app's Settings.

# convert.py --provider deepseek    (DEFAULT — DeepSeek-V3, cheap & fast for big runs)
DEEPSEEK_API_KEY=

# convert.py --provider anthropic
ANTHROPIC_API_KEY=

# convert.py --provider openai
OPENAI_API_KEY=

# convert.py --provider gemini
GEMINI_API_KEY=

# convert.py --provider moonshot
MOONSHOT_API_KEY=

# convert.py --provider mistral
MISTRAL_API_KEY=
